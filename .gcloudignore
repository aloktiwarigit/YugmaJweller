# gcloudignore — tuned for Firebase App Hosting web-only source deploy.
# Target: apps/customer-web only. Everything else excluded.

# Git internals
.git/
.github/

# ALL other apps — only customer-web is needed for this deploy
apps/shopkeeper/
apps/api/
apps/customer-mobile/
apps/admin-web/

# Build outputs from customer-web (rebuilt on Firebase build servers)
apps/customer-web/.next/
apps/customer-web/out/
apps/customer-web/node_modules/

# Workspace package compiled outputs — not needed for Next.js (uses transpilePackages)
packages/*/dist/
packages/integrations/*/dist/

# pnpm virtual store (rebuilt on Firebase build servers)
node_modules/
.pnpm-store/

# Dev tooling and local artifacts
.playwright-mcp/
.claude/
.remember/
.serena/
docs/
_bmad-output/
artifacts/
tools/

# Test / coverage outputs
coverage/
*.tsbuildinfo

# Local env secrets
.env
.env.*
!.env.example
!.env.*.example

# OS
.DS_Store
Thumbs.db

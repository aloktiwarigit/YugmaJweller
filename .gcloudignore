# gcloudignore for Cloud Build API docker builds (submitted from repo root).
# Firebase App Hosting now uses GitHub integration (not local gcloud upload),
# so this file is optimised for the API build context only.
#
# Include: apps/api/, packages/ (source + compiled dist/), workspace manifests
# Exclude: other apps, node_modules (rebuilt in Docker), dev artifacts

# Git internals
.git/
.github/

# Other apps — not needed to build the API Docker image
apps/shopkeeper/
apps/customer-web/
apps/customer-mobile/
apps/admin-web/

# Next.js build outputs (not needed for API)
apps/customer-web/.next/
apps/customer-web/out/

# Dev tooling and local artifacts
.playwright-mcp/
.claude/
.remember/
.serena/
docs/
_bmad-output/
artifacts/
tools/

# pnpm virtual store — rebuilt inside Docker via pnpm install
node_modules/
.pnpm-store/

# Test / coverage outputs
coverage/
*.tsbuildinfo

# Local env secrets
.env
.env.*
!.env.example
!.env.*.example

# OS
.DS_Store
Thumbs.db

# Local Claude Code harness config + session memory (per-machine, not source)
.claude/
.remember/

# Node / pnpm / Turborepo
node_modules/
dist/
.turbo/
coverage/
*.tsbuildinfo

# Env + secrets
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key

# Service account JSON keys (Firebase Admin SDK, GCP service accounts).
# Pattern covers .secrets/ root plus filename conventions from gcloud/firebase.
.secrets/
*-service-account*.json
*-adminsdk*.json
firebase-admin-sdk-*.json

# Firebase client config (public-by-design per Firebase's security model but
# still not committed — contains the project-specific Android/iOS GCP client
# IDs which we prefer to regenerate on-demand via `firebase apps:sdkconfig`).
# Also covered by apps/shopkeeper/.gitignore; root rule is defense-in-depth.
google-services.json
GoogleService-Info.plist

# Android keystores + iOS distribution credentials (per-tenant, never shared).
# Upload via `eas credentials` to EAS Vault; never commit.
*.keystore
*.p12
*.mobileprovision

# EAS credentials.json (populated copy with real keystore paths/passwords).
# The checked-in credentials.example.json is the safe reference template.
credentials.json

# Play Store service account JSON (used by eas submit --platform android).
*-play-store*.json
play-store-service-account.json

# Editor + OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Build artifacts
*.tgz

# Next.js build outputs (apps/customer-web — generated, never source)
apps/customer-web/.next/
apps/customer-web/.lighthouseci/
apps/customer-web/out/

# Local runtime markers (generated by CI/scripts, not source)
.codex-review-passed
.worktrees/

# StubStorageAdapter scratch dir (created by API boot in dev/smoke mode)
apps/api/tmp/

# TypeScript build outputs leaked into package src/test (emit belongs in dist/)
packages/*/src/**/*.js
packages/*/src/**/*.d.ts
packages/*/src/**/*.js.map
packages/*/test/**/*.js
packages/*/test/**/*.d.ts
packages/*/test/**/*.js.map

# Playwright MCP local cache
.playwright-mcp/

# Local QA / demo capture outputs (dev-server logs, device screenshots,
# Playwright trace dumps) — never source. artifacts/ is the canonical
# capture dir; loose PNGs at repo root are typically demo screenshots.
artifacts/
/*.png

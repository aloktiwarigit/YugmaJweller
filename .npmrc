engine-strict=false
auto-install-peers=true
strict-peer-dependencies=false

# React Native packages' postinstall hooks (bob build, husky install) need
# tooling hoisted; pnpm's strict isolation otherwise breaks CI install.
# @babel/runtime must also be hoisted — Metro resolver walks node_modules/
# looking for @babel/runtime/helpers at the root; pnpm strict isolation hides it.
public-hoist-pattern[]=*react-native-builder-bob*
public-hoist-pattern[]=*bob*
public-hoist-pattern[]=husky
public-hoist-pattern[]=@babel/runtime
# Metro needs pnpm-isolated React Native sub-packages at the workspace root
public-hoist-pattern[]=@react-native/*
public-hoist-pattern[]=expo-modules-core

# Skip native-build postinstalls for packages we ship only as JS (CI runs
# `expo export --platform web`, not a native RN build).
neverBuiltDependencies[]=react-native-screens
neverBuiltDependencies[]=cpu-features

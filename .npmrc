engine-strict=false
auto-install-peers=true
strict-peer-dependencies=false

# React Native + Windows + pnpm:
# - Metro's resolver cannot follow pnpm's symlinked .pnpm/ layout
# - Android NDK + ninja fail Windows 260-char path limit when crossing .pnpm/ symlinks
# `node-linker=hoisted` makes pnpm produce a flat node_modules (like npm/yarn) —
# no .pnpm/ symlink directory at all. Trade-off: lose pnpm's strict-isolation
# guarantees workspace-wide, but this is the documented config for RN/Expo
# monorepos on Windows. See: https://pnpm.io/npmrc#node-linker
node-linker=hoisted

# React Native packages' postinstall hooks (bob build, husky install) need
# tooling hoisted; pnpm's strict isolation otherwise breaks CI install.
public-hoist-pattern[]=*react-native-builder-bob*
public-hoist-pattern[]=*bob*
public-hoist-pattern[]=husky

# Metro + Expo require several runtime helpers be resolvable from anywhere
# in the workspace — pnpm's strict isolation hides them in .pnpm/*/node_modules
# where Metro's resolver can't follow symlinks. Hoist the known-required set:
public-hoist-pattern[]=@babel/runtime
public-hoist-pattern[]=expo-modules-core
public-hoist-pattern[]=@expo/*
public-hoist-pattern[]=@react-native/*
public-hoist-pattern[]=@react-native-community/*
public-hoist-pattern[]=react-native-*
public-hoist-pattern[]=expo-*
public-hoist-pattern[]=scheduler
public-hoist-pattern[]=metro-runtime
public-hoist-pattern[]=react-freeze

# Skip native-build postinstalls for packages we ship only as JS (CI runs
# `expo export --platform web`, not a native RN build).
neverBuiltDependencies[]=react-native-screens
neverBuiltDependencies[]=cpu-features

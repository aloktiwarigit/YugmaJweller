# apps/api/.env.example — copy to .env.local (gitignored) and fill in real values.

# Firebase Auth (server-side Admin SDK — see apps/api/src/modules/auth/firebase-admin.provider.ts)
FIREBASE_PROJECT_ID=goldsmith-dev
# Base64 encoding of the Admin SDK service account JSON.
# To regenerate: base64 -w0 .secrets/firebase-admin-sdk-goldsmith-dev.json
FIREBASE_SERVICE_ACCOUNT_JSON_B64=

# Postgres (local Docker per docs/runbook.md §3)
DATABASE_URL=postgres://goldsmith:goldsmith@localhost:5432/goldsmith

# Platform-admin Postgres connection (separate role per migration 0000_roles.sql).
# `app_user` (DATABASE_URL above) has no membership in `platform_admin`, so platform-admin
# services connect directly as platform_admin via this URL.
# Falls back to DATABASE_URL for local dev where role separation is typically absent.
DATABASE_URL_ADMIN=postgres://platform_admin:placeholder_platform_admin@localhost:5432/goldsmith

# Admin web origin allowlist (comma-separated) for CORS on platform admin browser calls.
# Production: set to https://admin.goldsmith.example. Dev default in code: http://localhost:3000.
# ADMIN_WEB_ORIGIN=http://localhost:3000

# Impersonation JWT signing secret (HS256). MUST be ≥32 bytes — generate via:
#   openssl rand -base64 48
# IMPERSONATION_JWT_SECRET=

# App port (NestJS default)
PORT=3000

# =============================================================================
# Goldsmith Customer Mobile — Production Build Environment Variables
# =============================================================================
# Copy this file and populate the values for each tenant build.
# See docs/runbook.md §17 for step-by-step guidance.
#
# WHITE-LABEL: Every tenant gets a separate build with their own values.
#   Do NOT share one APK/IPA across tenants.
#
# SECURITY: Never commit a populated copy of this file.
#   The real .env.production file (without .example suffix) is gitignored.
#   Pass values to EAS via `eas secret:push` or the EAS dashboard.
# =============================================================================

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------

# Base URL of the production API. MUST start with https://.
# App config validates this at build time — build fails if http:// or empty.
# Example: https://api.aanchaljewellers.com
EXPO_PUBLIC_API_BASE_URL=REPLACE_WITH_PRODUCTION_HTTPS_API_URL

# Tenant slug matching the `slug` column in the shops table.
# Used for the /tenant/boot call at startup.
# Example: aanchal-ayodhya-01
EXPO_PUBLIC_SHOP_SLUG=REPLACE_WITH_TENANT_SLUG

# ---------------------------------------------------------------------------
# App Identity (per-tenant — drives white-label branding)
# ---------------------------------------------------------------------------

# Display name shown in the OS app drawer and splash screen.
# Use the tenant's official Hindi app name.
# Example: आँचल ज्वैलर्स
EXPO_PUBLIC_APP_NAME=REPLACE_WITH_TENANT_APP_NAME_IN_HINDI

# Android package name. MUST be unique per tenant on the Play Store.
# Convention: com.<tenant_reverse_domain>.customer
# Example: com.aanchaljewellers.customer
EXPO_PUBLIC_ANDROID_PACKAGE=REPLACE_WITH_TENANT_ANDROID_PACKAGE

# iOS bundle identifier. MUST be unique per tenant on the App Store.
# Convention: com.<tenant_reverse_domain>.customer
# Example: com.aanchaljewellers.customer
EXPO_PUBLIC_IOS_BUNDLE_ID=REPLACE_WITH_TENANT_IOS_BUNDLE_ID

# ---------------------------------------------------------------------------
# Firebase
# ---------------------------------------------------------------------------

# Firebase project ID for this tenant's production Firebase project.
# Source: Firebase Console → Project settings → General → Project ID.
# Example: aanchal-jewellers-prod
EXPO_PUBLIC_FIREBASE_PROJECT_ID=REPLACE_WITH_PRODUCTION_FIREBASE_PROJECT_ID

# ---------------------------------------------------------------------------
# EAS Project
# ---------------------------------------------------------------------------

# EAS project ID — created via `eas project:init` for this tenant.
# Stored in app.config.ts extra.eas.projectId.
# Example: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
EXPO_PUBLIC_EAS_PROJECT_ID=REPLACE_WITH_EAS_PROJECT_ID

# ---------------------------------------------------------------------------
# Dev-mode bypass (MUST be 0 in production)
# ---------------------------------------------------------------------------

# Disables Firebase Auth and accepts a mock phone+OTP for dev convenience.
# MUST be "0" for every production build. App config validates this.
EXPO_PUBLIC_DEV_AUTH=0

# Native folders are generated by Expo prebuild/run commands for local device
# testing. Keep source-of-truth Android fixes in app.config.ts plugins.
android/
ios/

# Expo CLI metadata — generated at runtime; includes typed routes that depend
# on local file layout and can pollute with monorepo paths if not ignored.
.expo/

# Expo-generated local type file.
expo-env.d.ts

# Firebase app config is tenant/build specific.
google-services.json
GoogleService-Info.plist

# Android keystores + iOS credentials — uploaded to EAS Vault, never committed.
*.keystore
*.p12
*.mobileprovision

# Populated EAS credentials file (credentials.example.json is the safe template).
credentials.json

# Populated production env file (only .env.production.example is committed).
.env.production

# Play Store submission service account key.
*-play-store*.json
play-store-service-account.json

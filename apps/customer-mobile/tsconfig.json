{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["nativewind/types", "node", "vitest/globals"]
  },
  "include": [
    "app/**/*",
    "src/**/*",
    "test/**/*",
    "app.config.ts",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}

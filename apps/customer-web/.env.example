# apps/customer-web/.env.example — copy to .env.local and fill in real values.

# Backend API base. Used by lib/api.ts for SSR (server-to-server) and
# app/admin/_lib/admin-api.ts for the platform admin browser console.
API_URL=http://localhost:3001
NEXT_PUBLIC_API_BASE=http://localhost:3001

# Multi-tenant theming — for dev, pin a default shop slug. In prod the slug
# comes from the request host via middleware.
NEXT_PUBLIC_SHOP_SLUG=anchor-dev

# Firebase Web SDK (platform admin /admin only). Values come from Firebase
# console → Project settings → General → Your apps → Web app.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=goldsmith-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=goldsmith-dev
NEXT_PUBLIC_FIREBASE_APP_ID=

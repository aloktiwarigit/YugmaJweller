# apps/customer-web/.env.example
# Copy to .env.local for local development and fill in real values.
# For production (App Hosting / manual deploy): see .env.production.example
# and docs/runbook.md §17 (App Hosting deploys).
#
# Variables marked [apphosting.yaml] are also set in apphosting.yaml per-tenant.
# Variables marked [env.ts required] are validated at build time by lib/env.ts.
# NEVER commit real credentials — this file contains placeholder values only.

# ── Node / Next.js platform ───────────────────────────────────────────────────
NODE_ENV=development
# Disable Next.js telemetry in all environments.
NEXT_TELEMETRY_DISABLED=1

# ── Tenant identity ───────────────────────────────────────────────────────────
# [apphosting.yaml] [env.ts required]
# The jeweller's slug as stored in the database shops.slug column.
# One App Hosting backend deployment = one tenant.
# Source: Firebase console → App Hosting → backend env, or from the tenant
# provisioning step in docs/runbook.md §7.
NEXT_PUBLIC_SHOP_SLUG=anchor-dev

# ── API endpoints ─────────────────────────────────────────────────────────────
# [apphosting.yaml]
# Server-to-server URL used during SSR (not exposed to the browser).
# Local dev: http://localhost:3001
# Production (Cloud Run): https://<service>.<region>.run.app
API_URL=http://localhost:3001

# [apphosting.yaml] [env.ts required]
# Browser-accessible API base — inlined into the client JS bundle at build time.
# Must be the same service as API_URL and reachable from the customer's browser.
NEXT_PUBLIC_API_BASE=http://localhost:3001

# [apphosting.yaml] [env.ts required]
# Canonical public URL of this tenant's storefront.
# Used for sitemap.xml absolute URLs and Open Graph meta tags.
# Production: the Firebase App Hosting assigned domain or custom domain.
# Example: https://goldsmith-customer-web--goldsmith-dev.asia-east1.hosted.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Firebase Web SDK ──────────────────────────────────────────────────────────
# [apphosting.yaml]
# Public keys — safe to commit in apphosting.yaml (restricted by Firebase
# security rules). Source: Firebase console → Project settings → General →
# Your apps → Web app → SDK setup and configuration.
# Required for the platform /admin console login via Firebase Auth.
# All four fields below must be set together or the admin console will fail.

# Web API key (not the Admin SDK key — those are server-only and gitignored).
NEXT_PUBLIC_FIREBASE_API_KEY=

# Firebase project auth domain (format: <project-id>.firebaseapp.com).
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=goldsmith-dev.firebaseapp.com

# Firebase project ID — matches the project in Firebase console.
NEXT_PUBLIC_FIREBASE_PROJECT_ID=goldsmith-dev

# Web app ID from Firebase console (format: 1:<project-number>:web:<hash>).
NEXT_PUBLIC_FIREBASE_APP_ID=

# apps/customer-web/.env.production.example
# Copy to .env.production (NOT .env.local) and fill in real values before deploying.
# NEVER commit .env.production to git — it contains production credentials.

# ── Tenant identity ──────────────────────────────────────────────────────────
# The jeweller's slug in the database. One deployment = one tenant.
NEXT_PUBLIC_SHOP_SLUG=anchor-dev

# ── API ──────────────────────────────────────────────────────────────────────
# Server-to-server URL (used during static export build, not exposed to browser).
# For local Docker dev: http://localhost:3001
# For production Azure Container Apps: https://api.<tenant>.goldsmith.example.com
API_URL=https://api.anchor-dev.example.com

# Browser-accessible API base (inlined into client JS bundle at build time).
# Must be the same service as API_URL, accessible from the customer's browser.
NEXT_PUBLIC_API_BASE=https://api.anchor-dev.example.com

# ── Canonical site URL ───────────────────────────────────────────────────────
# Used for sitemap.xml absolute URLs and Open Graph meta tags.
# Must match the Firebase Hosting custom domain.
NEXT_PUBLIC_SITE_URL=https://jeweller.example.com

# ── Firebase Admin SDK (platform /admin console) ─────────────────────────────
# Get these from Firebase console → Project settings → General → Web app.
# Leave empty if the /admin route is not used on this deployment.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=goldsmith-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=goldsmith-prod
NEXT_PUBLIC_FIREBASE_APP_ID=

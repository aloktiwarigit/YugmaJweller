# apps/customer-web/.env.production.example
# Copy to .env.production for a real customer-web production build.
# Do not commit .env.production; values are tenant/environment specific.
#
# Production validation rejects missing values, localhost, and non-HTTPS API/site
# URLs. Replace every value below before building a release artifact.

# Tenant identity. One customer-web production deployment serves one tenant.
NEXT_PUBLIC_SHOP_SLUG=tenant-prod-slug

# Server-to-server API origin used by SSR/runtime fetches.
API_URL=https://api.tenant.example.com

# Browser-accessible API origin baked into the client bundle at build time.
NEXT_PUBLIC_API_BASE=https://api.tenant.example.com

# Canonical customer storefront URL for metadata, sitemaps, and share links.
NEXT_PUBLIC_SITE_URL=https://shop.tenant.example.com

# Firebase Web SDK public config for the production Firebase project.
NEXT_PUBLIC_FIREBASE_API_KEY=replace-with-firebase-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tenant-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tenant-prod
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

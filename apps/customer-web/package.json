{
  "name": "@goldsmith/customer-web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "test": "vitest run",
    "test:lighthouse-ci": "node scripts/run-lhci.mjs",
    "test:axe": "node scripts/run-lhci.mjs -- --config=lighthouserc.cjs --collect.settings.onlyCategories=accessibility",
    "deploy": "firebase deploy --only apphosting:goldsmith-customer-web --project goldsmith-dev",
    "deploy:dry-run": "firebase deploy --only apphosting:goldsmith-customer-web --project goldsmith-dev --dry-run"
  },
  "dependencies": {
    "@goldsmith/auth-client": "workspace:*",
    "@goldsmith/customer-shared": "workspace:*",
    "@goldsmith/ui-tokens": "workspace:*",
    "@goldsmith/ui-web": "workspace:*",
    "@sentry/nextjs": "^8.55.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "firebase": "^11.0.0",
    "next": "14.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}

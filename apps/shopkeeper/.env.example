EXPO_PUBLIC_APP_NAME=Ayodhya Swarnkar

# Development defaults. These can be omitted locally because app.config.ts
# falls back to them unless EAS_BUILD_PROFILE=production.
# Android emulator: use 10.0.2.2 (maps to host machine localhost)
# iOS simulator: localhost works fine
# Physical device: use your machine's LAN IP (e.g. http://192.168.1.x:3000)
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3000
EXPO_PUBLIC_TENANT_SLUG=anchor-dev
EXPO_PUBLIC_FIREBASE_PROJECT_ID=goldsmith-dev

# Required for EAS production builds.
# Keep real production values in EAS environment variables, not in this file.
# EXPO_PUBLIC_API_BASE_URL=https://api.example.com
# EXPO_PUBLIC_TENANT_SLUG=anchor
# EXPO_PUBLIC_FIREBASE_PROJECT_ID=goldsmith-prod
# EXPO_PUBLIC_FIREBASE_API_KEY=
# EXPO_PUBLIC_FIREBASE_APP_ID=
# EXPO_PUBLIC_ANDROID_PACKAGE=com.goldsmith.shopkeeper
# EXPO_PUBLIC_IOS_BUNDLE_IDENTIFIER=com.goldsmith.shopkeeper
# EXPO_PUBLIC_EAS_PROJECT_ID=

  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/react": "^14.3.1",
    "@types/react": "~18.2.79",
    "axe-core": "^4.9.0",
    "axios-mock-adapter": "^1.22.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
